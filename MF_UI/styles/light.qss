/* ============================================
   MF-Mathematics - 亮色主题
   ============================================ */

/* ---- 全局 ---- */
QMainWindow {
    background-color: #f8fafc;
    border-radius: 8px;
}
#mfShadowHost {
    background: transparent;
}
#framelessContainer {
    background: #f8fafc;
    border-radius: 8px;
}
QStatusBar {
    border-bottom-left-radius: 8px;
    border-bottom-right-radius: 8px;
}

/* ---- 自定义标题栏 ---- */
#customTitleBar {
    background: #ffffff;
    border-bottom: 1px solid #e2e8f0;
}
#mfDialogTitleBar {
    background: #ffffff;
    border-bottom: 1px solid #e2e8f0;
}
#mfDialogContent {
    background: #f8fafc;
}
#titlebar_icon {
    font-size: 16px;
    background: transparent;
}
#titlebar_title {
    font-size: 12px;
    font-weight: 600;
    color: #475569;
    background: transparent;
    padding-left: 4px;
}
#titlebar_btn_min, #titlebar_btn_max, #titlebar_btn_close {
    background: transparent;
    border: none;
    border-radius: 4px;
    color: #64748b;
    font-size: 13px;
    font-weight: 600;
}
#titlebar_btn_min:hover, #titlebar_btn_max:hover {
    background: #f1f5f9;
    color: #334155;
}
#titlebar_btn_close:hover {
    background: #ef4444;
    color: #ffffff;
}
#framelessContainer {
    background: #f8fafc;
}
#dialogInner {
    background: #f8fafc;
    border-radius: 10px;
}
QWidget {
    background-color: #f8fafc;
    color: #1e293b;
}

/* ---- 菜单栏 ---- */
QMenuBar {
    background-color: #ffffff;
    color: #1e293b;
    border-bottom: 1px solid #e2e8f0;
    padding: 2px 0;
}
QMenuBar::item {
    padding: 4px 12px;
    border-radius: 4px;
}
QMenuBar::item:selected {
    background-color: #e2e8f0;
}

QMenu {
    background-color: #ffffff;
    color: #1e293b;
    border: 1px solid #e2e8f0;
    padding: 4px;
}
QMenu::item {
    padding: 6px 32px 6px 16px;
    border-radius: 4px;
}
QMenu::item:selected {
    background-color: #e2e8f0;
}
QMenu::separator {
    height: 1px;
    background: #e2e8f0;
    margin: 4px 8px;
}

/* ---- 工具栏 ---- */
QToolBar {
    background-color: #ffffff;
    border-bottom: 1px solid #e2e8f0;
    padding: 4px 8px;
    spacing: 6px;
}
QToolBar QToolButton {
    color: #64748b;
    padding: 6px 16px;
    border: 1px solid transparent;
    border-radius: 6px;
    font-size: 13px;
}
QToolBar QToolButton:hover {
    background-color: #f1f5f9;
    color: #1e293b;
}
QToolBar QToolButton:checked {
    background-color: #3b82f6;
    color: #ffffff;
    border: 1px solid #2563eb;
}

/* ---- 状态栏 ---- */
QStatusBar {
    background-color: #ffffff;
    color: #475569;
    border-top: 1px solid #e2e8f0;
    padding: 2px 12px;
    font-size: 12px;
}
#brand_label {
    color: #94a3b8;
    font-size: 12px;
}

/* ============================================
   计算工作区 (BaseWorkspace)
   ============================================ */
#title_label {
    font-size: 20px;
    font-weight: 600;
    color: #0f172a;
    background: transparent;
}
#desc_label {
    font-size: 14px;
    color: #475569;
    background: transparent;
}
#work_card {
    background-color: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    padding: 12px;
}
#btn_add {
    border-top: 1px solid #d7d7d7;
    border-left: 1px solid #d7d7d7;
    border-right: 1px solid #d7d7d7;
    border-bottom: none;
    background-color: transparent;
    color: #94a3b8;
    font-size: 13px;
}
#btn_add:hover {
    background-color: #e0e2e4d8;
    color: #475569;
}

/* ---- 计算块分隔线 ---- */
#calc_separator {
    background-color: #e2e8f0;
    border: none;
}

/* ============================================
   计算块 (BaseCalcBlock)
   ============================================ */
CalcBlock {
    background-color: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    padding: 8px;
    margin: 4px 0px;
}

/* 计算块内的输入框 */
CalcBlock QLineEdit {
    border: 1px solid #d1d5db;
    border-radius: 4px;
    padding: 6px 10px;
    font-size: 13px;
    background-color: #fafafa;
    color: #1e293b;
    selection-background-color: #3b82f6;
}
CalcBlock QLineEdit:focus {
    border-color: #3b82f6;
    background-color: #ffffff;
}

/* 计算块内的下拉菜单 */
CalcBlock QComboBox {
    border: 1px solid #d1d5db;
    border-radius: 4px;
    padding: 6px 10px;
    font-size: 13px;
    background-color: #fafafa;
    color: #1e293b;
    min-width: 100px;
}
CalcBlock QComboBox:hover {
    background-color: #e2e8f0;
}
CalcBlock QComboBox::drop-down {
    border: none;
    width: 20px;
}
CalcBlock QComboBox::drop-arrow {
    width: 12px;
    height: 12px;
}

/* 计算按钮 */
QPushButton#calc_btn {
    background-color: #3b82f6;
    color: #ffffff;
    border: none;
    border-radius: 4px;
    padding: 6px 16px;
    font-size: 13px;
    font-weight: 500;
}
QPushButton#calc_btn:hover {
    background-color: #2563eb;
}
QPushButton#calc_btn:pressed {
    background-color: #1d4ed8;
}

/* 删除按钮 */
QPushButton#delete_btn {
    background-color: transparent;
    border: none;
    color: #94a3b8;
    font-size: 16px;
    font-weight: bold;
    padding: 4px 8px;
    border-radius: 4px;
}
QPushButton#delete_btn:hover {
    background-color: #fee2e2;
    color: #ef4444;
}
QPushButton#delete_btn:pressed {
    background-color: #fecaca;
}

/* ============================================
   绘图工作区 (PlotWorkspace)
   ============================================ */
#plot_title_label {
    font-size: 16px;
    font-weight: 600;
    color: #0f172a;
    background: transparent;
}
#plot_desc_label {
    font-size: 12px;
    color: #475569;
    background: transparent;
}
#plot_work_card {
    background-color: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    padding: 12px;
}
#plot_btn_add {
    border-top: 1px solid #d7d7d7;
    border-left: 1px solid #d7d7d7;
    border-right: 1px solid #d7d7d7;
    border-bottom: none;
    background-color: transparent;
    color: #94a3b8;
    font-size: 13px;
}
#plot_btn_add:hover {
    background-color: #e0e2e4d8;
    color: #475569;
}
#plot_left_panel {
    background-color: #f8fafc;
    border-right: 1px solid #e2e8f0;
}

/* ============================================
   函数框 (FunctionBox)
   ============================================ */
FunctionBox {
    background-color: #f9fafb;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    padding: 8px;
    margin: 2px 0;
}
FunctionBox QLineEdit {
    border: 1px solid #d1d5db;
    border-radius: 4px;
    padding: 3px 8px;
    font-size: 13px;
    background-color: #ffffff;
    color: #1e293b;
}
FunctionBox QLineEdit:focus {
    border-color: #3b82f6;
}

/* 函数框删除按钮 */
#func_del_btn {
    background-color: transparent;
    border: none;
    color: #94a3b8;
    font-size: 18px;
    font-weight: bold;
    padding: 0 4px;
}
#func_del_btn:hover {
    color: #ef4444;
    background-color: #fee2e2;
    border-radius: 4px;
}

/* 函数框可见性复选框 */
#func_vis_cb {
    font-size: 12px;
    color: #64748b;
    spacing: 4px;
}

/* 函数框序号标签 */
#func_index_lbl {
    font-weight: 600;
    font-size: 13px;
    color: #1e293b;
}

/* 参数滑块标签 */
#param_add_lbl {
    font-size: 11px;
    color: #94a3b8;
}

/* 参数添加按钮 */
#param_add_btn {
    background: #f1f5f9;
    border: 1px solid #cbd5e1;
    border-radius: 3px;
    padding: 1px 6px;
    font-size: 11px;
    color: #475569;
}
#param_add_btn:hover {
    background: #e2e8f0;
    border-color: #94a3b8;
}

/* ============================================
   滚动条 — 全局 + 计算区 + 绘图区
   ============================================ */

/* 全局滚动条基础 */
QScrollBar:vertical {
    width: 8px;
    background: transparent;
    border: none;
    margin: 4px 0 4px 0;
}
QScrollBar:horizontal {
    height: 8px;
    background: transparent;
    border: none;
    margin: 0 4px 0 4px;
}
QScrollBar::handle:vertical {
    background: #cbd5e1;
    border-radius: 4px;
    min-height: 36px;
}
QScrollBar::handle:vertical:hover {
    background: #94a3b8;
}
QScrollBar::handle:vertical:pressed {
    background: #64748b;
}
QScrollBar::handle:horizontal {
    background: #cbd5e1;
    border-radius: 4px;
    min-width: 36px;
}
QScrollBar::handle:horizontal:hover {
    background: #94a3b8;
}
QScrollBar::add-line,
QScrollBar::sub-line {
    height: 0px;
    width: 0px;
    border: none;
    background: none;
}
QScrollBar::add-page,
QScrollBar::sub-page {
    background: none;
}
QScrollBar::up-arrow,
QScrollBar::down-arrow,
QScrollBar::left-arrow,
QScrollBar::right-arrow {
    width: 0px;
    height: 0px;
    border: none;
    background: none;
}

/* 计算工作区滚动条 — 略宽，更醒目 */
#calcScroll QScrollBar:vertical {
    width: 10px;
}
#calcScroll QScrollBar::handle:vertical {
    background: #cbd5e1;
    border-radius: 5px;
    min-height: 40px;
}
#calcScroll QScrollBar::handle:vertical:hover {
    background: #94a3b8;
}

/* 绘图区滚动条 — 保持现有风格 */
#plotScroll QScrollBar:vertical {
    width: 10px;
}
#plotScroll QScrollBar::handle:vertical {
    background: #cbd5e1;
    border-radius: 5px;
    min-height: 36px;
}
#plotScroll QScrollBar::handle:vertical:hover {
    background: #94a3b8;
}

QScrollArea {
    background: transparent;
    border: none;
}

/* ---- 键盘切换按钮 ---- */
#kb_toggle_btn {
    background: #3b82f6;
    color: #ffffff;
    border: none;
    border-radius: 6px;
    padding: 6px 14px;
    font-size: 12px;
    font-weight: 500;
}
#kb_toggle_btn:hover { background: #2563eb; }

/* ---- 虚拟键盘 ---- */
KeyboardPanel {
    background: #ffffff;
    border-top: 1px solid #e2e8f0;
}
KeyboardPanel QTabWidget::pane {
    border: none;
    background: #ffffff;
    padding: 2px;
}
KeyboardPanel QTabBar::tab {
    background: #f1f5f9;
    color: #64748b;
    padding: 4px 10px;
    border: 1px solid #e2e8f0;
    border-bottom: none;
    border-radius: 4px 4px 0 0;
}
KeyboardPanel QTabBar::tab:selected {
    background: #ffffff;
    color: #1e293b;
    border-bottom: 2px solid #3b82f6;
}
#kb_btn {
    background: #fafafa;
    color: #1e293b;
    border: 1px solid #d1d5db;
    border-radius: 4px;
    padding: 4px 2px;
    font-size: 13px;
    min-width: 36px;
}
#kb_btn:hover {
    background: #e2e8f0;
    border-color: #94a3b8;
}
#kb_btn:pressed {
    background: #3b82f6;
    color: #ffffff;
    border-color: #2563eb;
}

/* ---- 占位页面 ---- */
#page_title {
    color: #1e293b;
    background: transparent;
}
#page_desc {
    color: #64748b;
    font-size: 13px;
    background: transparent;
}
/* ---- 绘图区滑块控件 ---- */
SliderFunctionBox {
    background-color: #f9fafb;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    padding: 8px;
    margin: 2px 0;
}
#slider_index_lbl {
    font-weight: 600;
    font-size: 13px;
    color: #1e293b;
}
#slider_val_btn {
    font-size: 11px;
    color: #475569;
    background: #f1f5f9;
    border: 1px solid #d1d5db;
    border-radius: 3px;
    padding: 1px 4px;
}
#slider_val_btn:hover { background: #e2e8f0; }
#slider_edit {
    border: 1px solid #d1d5db; border-radius: 3px;
    padding: 1px 4px; font-size: 11px; background: #fff; width: 52px;
}
#slider_del_btn {
    background: transparent; border: none; color: #94a3b8;
    font-size: 14px; font-weight: bold; padding: 0 2px;
}
#slider_del_btn:hover { color: #ef4444; }

/* ---- 向量场 ---- */
#vf_input {
    border: 1px solid #d1d5db;
    border-radius: 4px;
    padding: 6px 10px;
    font-size: 14px;
    background: #ffffff;
    color: #1e293b;
}
#vf_input:focus { border-color: #3b82f6; }
#vf_redraw_btn {
    background: #10b981;
    color: #ffffff;
    border: none;
    border-radius: 4px;
    padding: 6px 20px;
    font-weight: 500;
}
#vf_redraw_btn:hover { background: #059669; }

/* ---- 复数模式 ---- */
#complex_input {
    border: 1px solid #d1d5db;
    border-radius: 4px;
    padding: 6px 10px;
    font-size: 14px;
    background: #ffffff;
    color: #1e293b;
}
#complex_input:focus { border-color: #3b82f6; }
#complex_apply_btn {
    background: #3b82f6;
    color: #ffffff;
    border: none;
    border-radius: 4px;
    padding: 6px 16px;
    font-size: 13px;
    font-weight: 500;
}
#complex_apply_btn:hover { background: #2563eb; }
#complex_redraw_btn {
    background: #10b981;
    color: #ffffff;
    border: none;
    border-radius: 4px;
    padding: 8px 20px;
    font-size: 14px;
    font-weight: 500;
}
#complex_redraw_btn:hover { background: #059669; }
QPushButton#complex_mode_btn[active="true"] {
    background: #3b82f6;
    color: #ffffff;
    border: none;
    border-radius: 4px;
    padding: 6px 12px;
    font-size: 12px;
    font-weight: 500;
    text-align: left;
}
QPushButton#complex_mode_btn[active="false"] {
    background: #f1f5f9;
    color: #475569;
    border: 1px solid #d1d5db;
    border-radius: 4px;
    padding: 6px 12px;
    font-size: 12px;
    text-align: left;
}
QPushButton#complex_mode_btn[active="false"]:hover { background: #e2e8f0; }
#complex_waiting {
    font-size: 18px;
    color: #94a3b8;
    background: transparent;
}
#plot_sep { background: #e2e8f0; border: none; }

/* ---- 任意做图 ---- */
#arbitrary_panel {
    background: #f8fafc;
    border-right: 1px solid #e2e8f0;
}
#arbitrary_status {
    font-size: 11px;
    color: #64748b;
    background: #f1f5f9;
    border-top: 1px solid #e2e8f0;
}
#arbitrary_shape_list {
    border: 1px solid #e2e8f0;
    border-radius: 4px;
    background: #ffffff;
    font-size: 11px;
}
#arbitrary_shape_list::item { padding: 3px 6px; }
#arbitrary_shape_list::item:selected { background: #dbeafe; color: #1e40af; }
QPushButton#arbitrary_tool_active {
    background: #3b82f6;
    color: #ffffff;
    border: 1px solid #2563eb;
    border-radius: 6px;
    padding: 6px 8px;
    font-size: 14px;
    font-weight: 600;
}
QPushButton#arbitrary_tool_inactive {
    background: #f1f5f9;
    color: #475569;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    padding: 6px 8px;
    font-size: 14px;
}
QPushButton#arbitrary_tool_inactive:hover { background: #e2e8f0; }
#arbitrary_export_btn {
    color: #ffffff;
    border: none;
    border-radius: 4px;
    padding: 6px 12px;
    font-size: 12px;
    font-weight: 500;
}

/* ---- 积分限对话框 ---- */
#integralBoundsDialog {
    background: #f8fafc;
}
#integralBoundsDialog QLineEdit {
    border: 1px solid #d1d5db;
    border-radius: 4px;
    padding: 6px 10px;
    font-size: 14px;
    background: #ffffff;
    color: #1e293b;
}
#integralBoundsDialog QLineEdit:focus { border-color: #3b82f6; }
#integralBoundsDialog QDoubleSpinBox {
    border: 1px solid #d1d5db;
    border-radius: 4px;
    padding: 6px 10px;
    font-size: 14px;
    background: #ffffff;
    color: #1e293b;
}

/* ---- 分割器 ---- */
QSplitter::handle {
    background-color: #e2e8f0;
    width: 2px;
}
QSplitter::handle:hover {
    background-color: #94a3b8;
}

/* ---- AI 配置提示 ---- */
#aiConfigPrompt {
    background: #f8fafc;
}
#ai_prompt_title {
    font-size: 16px;
    font-weight: 700;
    color: #0f172a;
    background: transparent;
}
#ai_prompt_desc {
    font-size: 13px;
    color: #64748b;
    background: transparent;
    line-height: 1.6;
}

/* ---- 登录/注册/帮助 ---- */
#loginDialog, #registerDialog, #helpBrowser {
    background: #f8fafc;
}
#loginDialog QLineEdit, #registerDialog QLineEdit {
    border: 1px solid #d1d5db;
    border-radius: 6px;
    padding: 10px 14px;
    font-size: 14px;
    background: #ffffff;
    color: #1e293b;
}
#loginDialog QLineEdit:focus, #registerDialog QLineEdit:focus {
    border-color: #3b82f6;
}
#helpBrowser QTextBrowser {
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    background: #ffffff;
    font-size: 14px;
    padding: 20px;
    color: #1e293b;
}
#helpBrowser QTreeWidget {
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    background: #ffffff;
    font-size: 13px;
    padding: 4px;
    color: #1e293b;
}
#helpBrowser QTreeWidget::item {
    padding: 6px 8px;
    border-radius: 4px;
}
#helpBrowser QTreeWidget::item:hover { background: #f1f5f9; }
#helpBrowser QTreeWidget::item:selected {
    background: #eef2ff;
    color: #1e293b;
}

/* ============================================
   对话框 (QDialog)
   ============================================ */
#aiDialog, #settingsDialog, #searchDialog {
    background-color: #f8fafc;
}
#aiDialog QTextEdit, #settingsDialog QTextEdit, #searchDialog QTextEdit {
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    background: #ffffff;
    font-size: 13px;
    padding: 8px;
    color: #1e293b;
}
#aiDialog QLineEdit, #settingsDialog QLineEdit, #searchDialog QLineEdit,
#aiDialog QComboBox, #settingsDialog QComboBox, #searchDialog QComboBox {
    border: 1px solid #d1d5db;
    border-radius: 4px;
    padding: 5px 10px;
    font-size: 12px;
    background: #ffffff;
    color: #1e293b;
}
#aiDialog QLineEdit:focus, #settingsDialog QLineEdit:focus, #searchDialog QLineEdit:focus,
#aiDialog QComboBox:focus, #settingsDialog QComboBox:focus, #searchDialog QComboBox:focus {
    border-color: #3b82f6;
}
#aiDialog QGroupBox, #settingsDialog QGroupBox {
    font-weight: 600;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    margin-top: 10px;
    padding-top: 14px;
    background: #ffffff;
    color: #0f172a;
}
#aiDialog QGroupBox::title, #settingsDialog QGroupBox::title {
    subcontrol-origin: margin;
    left: 12px;
    padding: 0 6px;
    color: #0f172a;
}
#aiDialog QPushButton#ai_send_btn {
    background-color: #3b82f6;
    color: #ffffff;
    border: none;
    border-radius: 6px;
    padding: 8px 20px;
    font-size: 13px;
    font-weight: 500;
}
#aiDialog QPushButton#ai_send_btn:hover { background-color: #2563eb; }
#aiDialog QPushButton#ai_send_btn:disabled { background-color: #94a3b8; }
#aiDialog QPushButton#ai_stop_btn {
    background-color: #ef4444;
    color: #ffffff;
    border: none;
    border-radius: 6px;
    padding: 8px 20px;
    font-size: 13px;
    font-weight: 500;
}
#aiDialog QPushButton#ai_stop_btn:hover { background-color: #dc2626; }
#aiDialog QPushButton#ai_secondary_btn, #settingsDialog QPushButton#settings_secondary_btn {
    background: #f1f5f9;
    color: #475569;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    padding: 6px 14px;
    font-size: 12px;
}
#aiDialog QPushButton#ai_secondary_btn:hover, #settingsDialog QPushButton#settings_secondary_btn:hover {
    background: #e2e8f0;
}
#aiDialog QPushButton#ai_clear_btn {
    background: transparent;
    color: #94a3b8;
    border: none;
    font-size: 11px;
}
#aiDialog QPushButton#ai_clear_btn:hover { color: #ef4444; }
#aiDialog QLabel#ai_title, #settingsDialog QLabel#settings_title {
    font-size: 16px;
    font-weight: 600;
    color: #0f172a;
    background: transparent;
}
#aiDialog QLabel#ai_status, #settingsDialog QLabel#settings_status {
    font-size: 11px;
    color: #94a3b8;
    background: transparent;
}
#aiDialog QComboBox#ai_model_combo {
    border: 1px solid #d1d5db;
    border-radius: 4px;
    padding: 4px 8px;
    font-size: 12px;
    background: #ffffff;
    min-width: 140px;
}
#searchDialog QListWidget {
    border: 1px solid #e2e8f0;
    border-radius: 6px;
    background: #ffffff;
    font-size: 12px;
}
#searchDialog QListWidget::item {
    padding: 8px 10px;
    border-bottom: 1px solid #f1f5f9;
}
#searchDialog QListWidget::item:selected {
    background: #dbeafe;
    color: #1e40af;
}
#aiDialog QComboBox QAbstractItemView, #settingsDialog QComboBox QAbstractItemView,
#searchDialog QComboBox QAbstractItemView {
    background: #ffffff;
    color: #1e293b;
    selection-background-color: #3b82f6;
    border: 1px solid #e2e8f0;
}
#aiDialog QComboBox::drop-down, #settingsDialog QComboBox::drop-down,
#searchDialog QComboBox::drop-down {
    border: none;
    width: 20px;
}
/* 设置对话框选项卡 */
#settingsDialog QTabWidget::pane {
    border: 1px solid #e2e8f0;
    border-radius: 6px;
    background: #ffffff;
}
#settingsDialog QTabBar::tab {
    background: #f1f5f9;
    color: #64748b;
    padding: 6px 16px;
    border: 1px solid #e2e8f0;
    border-bottom: none;
    border-radius: 4px 4px 0 0;
    margin-right: 2px;
}
#settingsDialog QTabBar::tab:selected {
    background: #ffffff;
    color: #1e293b;
    border-bottom: 2px solid #3b82f6;
}
#settingsDialog QDialogButtonBox QPushButton {
    background: #3b82f6;
    color: #fff;
    border: none;
    border-radius: 4px;
    padding: 6px 20px;
    font-size: 13px;
}
#settingsDialog QDialogButtonBox QPushButton:hover { background: #2563eb; }
/* 步骤查看器 */
#stepViewer {
    background: #fafbfc;
}
#stepViewer QTextEdit {
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    background: #ffffff;
    font-size: 14px;
    padding: 12px;
}
#stepViewer QLabel#step_title {
    font-size: 16px;
    font-weight: 600;
    color: #0f172a;
    background: transparent;
}
