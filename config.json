{
  "math_guard": {
    "level1": {
      "max_ops": 500,
      "max_nest_depth": 10,
      "description": "Slow warning — expression may take >10s"
    },
    "level2": {
      "poly_degree_threshold": 10,
      "max_matrix_dim": 6,
      "max_series_range": 1000,
      "description": "Explosion risk — very high chance of hang"
    },
    "limit": {
      "num_sample_epsilon": [0.001, 1e-6],
      "max_diff_threshold": 0.001,
      "timeout_seconds": 5,
      "oscillation_patterns": [
        "sin(1/",
        "cos(1/"
      ]
    }
  },
  "plot": {
    "scene_range": 20000000,
    "zoom_min": 1e-6,
    "zoom_max": 2000,
    "initial_view": [-8, -6, 16, 12],
    "tick_px": 4,
    "font_px": 9,
    "axis_px": 2.0,
    "curve_px": 2.5,
    "colors": [
      "#e74c3c", "#3498db", "#2ecc71", "#f39c12",
      "#9b59b6", "#1abc9c", "#e67e22", "#e84393"
    ],
    "axes": {
      "axis_color": "#334155",
      "grid_color": "#e8ecf0",
      "tick_color": "#94a3b8",
      "edge_color": "#b0b8c0",
      "text_color": "#334155",
      "bg_color": "#fafbfc",
      "label_font": "Segoe UI",
      "label_font_size": 9,
      "tick_px": 8,
      "minor_px": 4,
      "label_offset_px": 8,
      "minors_per": 4
    }
  },
  "ai": {
    "daily_free_steps": 5,
    "daily_free_accelerations": 3,
    "providers": {
      "deepseek": {
        "model": "deepseek-chat",
        "endpoint": "https://api.deepseek.com/v1/chat/completions"
      },
      "openai": {
        "model": "gpt-4o-mini",
        "endpoint": "https://api.openai.com/v1/chat/completions"
      }
    },
    "default_provider": "deepseek"
  },
  "numerical": {
    "max_iterations": 10000000,
    "max_precision": 15,
    "ramanujan_timeout": 1
  }
}
